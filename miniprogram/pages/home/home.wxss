page {
  background-color: #f7f8fa;
}

.container {
  padding-bottom: 40rpx;
}

.header-section {
  background-color: #ffffff;
  padding: 40rpx 40rpx 60rpx 40rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.user-greeting {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.greeting-text {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.hello {
  font-size: 26rpx;
  color: #888;
}

.username {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
}

.search-bar-fake {
  background-color: #f0f2f5;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.search-placeholder {
  margin-left: 20rpx;
  color: #999;
  font-size: 28rpx;
}

.content-section {
  padding: 40rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 30rpx;
  display: block;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.category-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  height: 200rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.2s ease;
}

.category-card:active {
  transform: scale(0.98);
}

.icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.category-icon {
  width: 50rpx;
  height: 50rpx;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.arrow-icon {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  color: #ddd;
  font-size: 24rpx;
}
