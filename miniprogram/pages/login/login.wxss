.login-page {
  background:
    radial-gradient(circle at top left, rgba(196, 81, 53, 0.14), transparent 34%),
    linear-gradient(180deg, #f2ebe2 0%, #f8f4ee 42%, #f3eee5 100%);
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 40rpx;
  background: linear-gradient(135deg, #73171b 0%, #9c302c 48%, #d1824c 100%);
  color: #fff8f2;
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 243, 224, 0.14);
}

.hero-glow-left {
  width: 300rpx;
  height: 300rpx;
  top: -120rpx;
  left: -70rpx;
}

.hero-glow-right {
  width: 220rpx;
  height: 220rpx;
  right: -40rpx;
  bottom: -60rpx;
}

.hero-kicker {
  position: relative;
  z-index: 1;
  display: inline-block;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 240, 0.16);
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.hero-title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 28rpx;
  font-family: "Times New Roman", "Songti SC", serif;
  font-size: 60rpx;
  line-height: 1.18;
  font-weight: 700;
}

.hero-copy {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 248, 241, 0.88);
}

.hero-badges {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  margin-top: 32rpx;
  gap: 14rpx;
}

.hero-badge {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 240, 0.15);
  font-size: 24rpx;
  font-weight: 600;
}

.story-list {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.story-card {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
}

.story-index {
  min-width: 76rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #8a231f;
}

.story-copy {
  flex: 1;
  margin-left: 18rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #44362c;
}

.action-card {
  margin-top: 26rpx;
  padding: 34rpx 28rpx 28rpx;
}

.action-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #221914;
}

.action-copy {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #70635a;
}

.primary-button,
.secondary-button {
  width: 100%;
  padding: 28rpx 24rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-button {
  margin-top: 34rpx;
  background: linear-gradient(135deg, #892025, #cf7148);
  color: #fffaf5;
  box-shadow: 0 18rpx 32rpx rgba(143, 29, 32, 0.18);
}

.secondary-button {
  margin-top: 18rpx;
  background: #f7efe5;
  color: #73171b;
  border: 1rpx solid rgba(115, 23, 27, 0.12);
}
