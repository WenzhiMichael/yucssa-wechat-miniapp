<view wx:if="{{merchant}}" class="page-shell detail-page">
  <view class="detail-hero panel">
    <view class="detail-badge" style="background: {{merchant.surface}}; color: {{merchant.accent}};">
      <image
        wx:if="{{merchant.logo}}"
        class="detail-badge-image"
        src="{{merchant.logo}}"
        mode="aspectFit"
      ></image>
      <text wx:else>{{merchant.initials}}</text>
    </view>

    <text class="detail-name">{{merchant.name}}</text>
    <text wx:if="{{merchant.area || merchant.hours}}" class="detail-meta">{{merchant.area}}{{merchant.area && merchant.hours ? ' · ' : ''}}{{merchant.hours}}</text>
    <text wx:if="{{merchant.description}}" class="detail-description">{{merchant.description}}</text>

    <view class="detail-actions">
      <button class="detail-action primary-action" bindtap="copyOffer">复制优惠</button>
      <button class="detail-action" bindtap="openMap">打开地图</button>
    </view>
  </view>

  <view class="offer-card panel">
    <text class="offer-label">当前学生福利</text>
    <text class="offer-title">{{merchant.offerTitle}}</text>
    <text class="offer-copy">{{merchant.offerDetails}}</text>
  </view>

  <view class="info-card panel">
    <view class="info-row">
      <text class="info-label">地址</text>
      <text class="info-value">{{merchant.address}}</text>
    </view>
    <view wx:if="{{merchant.phone}}" class="info-divider"></view>
    <view wx:if="{{merchant.phone}}" class="info-row">
      <text class="info-label">电话</text>
      <button class="info-link" bindtap="callMerchant">{{merchant.phone}}</button>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <text class="info-label">操作</text>
      <button class="info-link" bindtap="copyAddress">复制地址</button>
    </view>
  </view>

  <view wx:if="{{merchant.redemptionSteps.length}}" class="steps-card panel">
    <text class="steps-title">领取方式</text>
    <block wx:for="{{merchant.redemptionSteps}}" wx:key="*this">
      <view class="step-row">
        <text class="step-index">0{{index + 1}}</text>
        <text class="step-copy">{{item}}</text>
      </view>
    </block>
  </view>

  <view wx:if="{{merchant.tags.length || merchant.perks.length}}" class="tag-card panel">
    <text class="steps-title">标签和体验感</text>
    <view class="tag-group">
      <block wx:for="{{merchant.tags}}" wx:key="*this">
        <text class="detail-tag">{{item}}</text>
      </block>
      <block wx:for="{{merchant.perks}}" wx:key="*this">
        <text class="detail-tag detail-tag-secondary">{{item}}</text>
      </block>
    </view>
  </view>

  <view wx:if="{{relatedMerchants.length}}" class="related-section">
    <text class="section-heading">同类推荐</text>
    <view class="related-list">
      <block wx:for="{{relatedMerchants}}" wx:key="id">
        <button class="related-card panel" bindtap="openMerchant" data-id="{{item.id}}">
          <view class="related-mark" style="background: {{item.surface}}; color: {{item.accent}};">
            <image
              wx:if="{{item.logo}}"
              class="related-mark-image"
              src="{{item.logo}}"
              mode="aspectFit"
            ></image>
            <text wx:else>{{item.initials}}</text>
          </view>
          <view class="related-copy-block">
            <text class="related-name">{{item.name}}</text>
            <text class="related-copy">{{item.offerTitle}}</text>
          </view>
        </button>
      </block>
    </view>
  </view>
</view>
