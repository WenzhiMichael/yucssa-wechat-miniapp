page {
  background-color: #f7f8fa;
}

.banner-section {
  position: relative;
  height: 440rpx;
  width: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);
}

.header-content {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  display: flex;
  align-items: center;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-right: 24rpx;
  background-color: #fff;
}

.name {
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}

.content-body {
  padding: 30rpx;
  margin-top: -30rpx; /* Slight overlap if desired, or 0 */
  position: relative;
  z-index: 10;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.verified-badge {
  font-size: 20rpx;
  color: #07c160;
  background-color: #E6F7EF;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.discount-content {
  background-color: #FFF9F9;
  border: 1px dashed #FFCCCC;
  padding: 30rpx;
  border-radius: 12rpx;
  text-align: center;
}

.discount-big {
  display: block;
  font-size: 32rpx;
  color: #C1272D;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.discount-note {
  font-size: 22rpx;
  color: #999;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}

.info-label {
  color: #888;
  font-size: 28rpx;
}

.info-value {
  color: #333;
  font-size: 28rpx;
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}

.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

.description-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}
