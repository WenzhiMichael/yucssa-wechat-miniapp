page {
  background-color: #f7f8fa;
}

.container {
  padding: 30rpx;
}

.merchant-list {
  display: flex;
  flex-direction: column;
}

.merchant-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  transition: opacity 0.2s;
}

.merchant-card:active {
  opacity: 0.8;
}

.card-left {
  margin-right: 24rpx;
}

.merchant-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background-color: #f0f0f0;
  border: 1rpx solid #eee;
}

.card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.merchant-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.merchant-address {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  margin-bottom: 16rpx;
}

.discount-badge {
  align-self: flex-start;
  background-color: #fff0f0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1px solid #ffcccc;
}

.discount-text {
  color: #C1272D;
  font-size: 22rpx;
  font-weight: 600;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #ccc;
}
