.merchant-page {
  min-height: 100vh;
  padding: 20rpx 0 40rpx;
  background: #ffffff;
}

.merchant-section {
  margin-top: 18rpx;
  padding: 0 0 20rpx;
  border-top: 1rpx solid #f1f1f1;
}

.section-title-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 18rpx;
}

.section-title-bar {
  width: 6rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: #16c4c9;
  margin-right: 16rpx;
}

.section-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #12bfc3;
}

.merchant-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: 36rpx;
  column-gap: 8rpx;
  padding: 24rpx 16rpx 0;
}

.merchant-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 250rpx;
  padding: 0 10rpx;
  background: transparent;
}

.merchant-logo-shell {
  width: 150rpx;
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchant-logo-circle {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  border: 2rpx solid currentColor;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f6f6f6;
}

.merchant-logo-text {
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.merchant-logo-image {
  width: 92rpx;
  height: 92rpx;
}

.merchant-grid-name {
  display: -webkit-box;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #111111;
  text-align: center;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.empty-copy {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6d6d6d;
}
