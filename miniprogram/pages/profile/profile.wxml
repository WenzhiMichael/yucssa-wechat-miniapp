<view wx:if="{{profile}}" class="page-shell profile-page">
  <view class="profile-card panel">
    <view class="profile-top">
      <view class="profile-avatar">
        <image
          wx:if="{{profile.avatarUrl}}"
          class="profile-avatar-image"
          src="{{profile.avatarUrl}}"
          mode="aspectFill"
        ></image>
        <text wx:else class="profile-avatar-text">{{profileInitial}}</text>
      </view>

      <view class="profile-copy-block">
        <text class="profile-name">{{profile.nickName}}</text>
        <text class="profile-membership">{{profile.membershipLevel}} · {{profile.joinedLabel}}</text>
        <text class="profile-bio">{{profile.bio}}</text>
      </view>
    </view>

    <view class="profile-meta-grid">
      <view class="profile-meta-card">
        <text class="profile-meta-label">组织</text>
        <text class="profile-meta-value">{{profile.faculty}}</text>
      </view>
      <view class="profile-meta-card">
        <text class="profile-meta-label">会员码</text>
        <text class="profile-meta-value">{{profile.memberCode}}</text>
      </view>
    </view>

    <button class="profile-main-button" bindtap="copyMemberCode">复制会员码</button>
  </view>

  <view class="profile-section">
    <text class="section-heading">联系学生会</text>
    <view class="channel-list">
      <block wx:for="{{supportChannels}}" wx:key="id">
        <view class="channel-card panel">
          <view class="channel-copy-block">
            <text class="channel-label">{{item.label}}</text>
            <text class="channel-value">{{item.value}}</text>
            <text class="channel-description">{{item.description}}</text>
          </view>
          <button class="channel-button" bindtap="copyChannel" data-value="{{item.value}}">复制</button>
        </view>
      </block>
    </view>
  </view>

  <button class="logout-button" bindtap="logout">退出体验账号</button>
</view>
